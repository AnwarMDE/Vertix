{
  "expo": {
    "name": "Vertix",
    "slug": "surebets-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sureedge",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0f141c",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0f141c",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.surebets.sureedge",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "app.surebets.sureedge",
      "adaptiveIcon": {
        "backgroundColor": "#0f141c"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-secure-store",
      "expo-status-bar"
    ]
  }
}
